import os
import pandas as pd
import json
import seaborn as sns
import matplotlib.pyplot as plt

# ============================================================
# 1. OMEGA LOAD + INTEGRATION
# ============================================================
def omega_load_and_integration():

    print("\n OMEGA SYSTEM STARTED\n")

    required_files = ["zoo.csv", "class.csv", "auxiliary_metadata.json"]
    print("📥 Step 1: Checking required files...")

    missing = [f for f in required_files if not os.path.exists(f)]
    if missing:
        print(" Missing files:", missing)
        raise FileNotFoundError(f"Missing: {missing}")
    else:
        print(" All required files found!\n")

    print("📥 Loading files...")
    zoo = pd.read_csv("zoo.csv")
    class_df = pd.read_csv("class.csv")

    with open("auxiliary_metadata.json") as f:
        metadata = json.load(f)

    print(" Loaded zoo.csv")
    print(" Loaded class.csv")
    print(" Loaded auxiliary_metadata.json\n")

    print("🔎 Inspecting columns...")
    print("   ZOO Columns:", list(zoo.columns))
    print("   CLASS Columns:", list(class_df.columns))

    left_key = "class_type"
    right_key = "Class_Number"

    if left_key not in zoo.columns:
        raise KeyError(f"Column '{left_key}' not found in zoo.csv")
    if right_key not in class_df.columns:
        raise KeyError(f"Column '{right_key}' not found in class.csv")

    print(f"🔗 Merging {left_key} <==> {right_key}")
    df = zoo.merge(class_df, left_on=left_key, right_on=right_key, how="left")

    print("✅ Merge successful!\n")

    return df, metadata


# ============================================================
# 2. OMEGA NORMALIZATION
# ============================================================
def omega_normalization(df):
    print("✨ Starting Normalization...\n")

    df["_lower_name"] = df["animal_name"].str.lower()
    df = df.drop_duplicates(subset="_lower_name", keep="first")
    df = df.drop(columns="_lower_name")

    print("✔ Duplicate handling done!")
    print("✨ Normalization Complete.\n")
    return df


# ============================================================
# 3. OMEGA HANDLE MISSING VALUES
# ============================================================
def omega_handle_missing_values(df):

    print("\n🩺 Handling Missing Values...\n")

    cat = df.select_dtypes(include=["object"]).columns
    num = df.select_dtypes(include=["number"]).columns

    print("🔍 Before Filling Missing Values:")
    print(df.isna().sum(), "\n")

    df[cat] = df[cat].fillna("unknown")
    for c in num:
        df[c] = df[c].fillna(df[c].median())

    print("✔ Missing values handled successfully!")
    print("🔍 After Filling Missing Values:")
    print(df.isna().sum(), "\n")

    print(df.head(), "\n")
    return df


# ============================================================
# 4. OMEGA FEATURE ENGINEERING
# ============================================================
def omega_feature_engineering(df):

    print("\n🧬 OMEGA FEATURE ENGINEERING STARTED\n")

    # Feature 1
    print("🔧 Creating 'warm_blooded' feature...")
    df["warm_blooded"] = ((df["hair"] == 1) | (df["milk"] == 1)).astype(int)

    # Feature 2
    print("🔧 Creating 'movement_type' feature...")
    def classify_movement(row):
        if row["airborne"] == 1:
            return "air"
        if row["aquatic"] == 1:
            return "water"
        return "land"

    df["movement_type"] = df.apply(classify_movement, axis=1)

    print("✔ Feature Engineering Complete!\n")
    print(df[["animal_name", "warm_blooded", "movement_type"]].head(), "\n")

    return df


# ============================================================
# 5. EDA — 53_eda_and_cleaning
# ============================================================
def eda_53_and_cleaning(df):

    print("\n📊=======================================")
    print("OMEGA: 53_EDA_AND_CLEANING — STARTED")
    print("📊=======================================\n")

    # ---------------------------------------------------------
    # PIE CHART
    # ---------------------------------------------------------
    print("📌 Pie Chart: Class Distribution")
    plt.figure(figsize=(7, 7))
    df['Class_Type'].value_counts().plot(
        kind='pie', autopct='%1.1f%%', startangle=90
    )
    plt.title("Class Distribution")
    plt.ylabel("")
    plt.show()
    print("✔ Pie Chart Completed.\n")

    # ---------------------------------------------------------
    # RIDGE PLOT (KDE)
    # ---------------------------------------------------------
    print("📌 Ridge Plot: Legs vs Fins Distribution")
    plt.figure(figsize=(10, 6))
    sns.kdeplot(df["legs"], fill=True, alpha=0.5, label="Legs")
    sns.kdeplot(df["fins"], fill=True, alpha=0.5, label="Fins")
    plt.title("Distribution of Legs & Fins")
    plt.legend()
    plt.show()
    print("✔ Ridge Plot Completed.\n")

    # ---------------------------------------------------------
    # COUNT PLOT
    # ---------------------------------------------------------
    print("📌 Count Plot: Habitat by Diet")
    plt.figure(figsize=(10, 6))
    sns.countplot(data=df, x="habitat", hue="diet")
    plt.title("Habitat Type by Diet")
    plt.xticks(rotation=45)
    plt.show()
    print("✔ Count Plot Completed.\n")

    # ---------------------------------------------------------
    # HEATMAP
    # ---------------------------------------------------------
    print("📌 Heatmap: Feature Correlation")
    numeric_df = df.select_dtypes(include=["number"])

    plt.figure(figsize=(12, 8))
    sns.heatmap(
        numeric_df.corr(),
        annot=True,
        cmap="coolwarm",
        fmt=".2f",
        linewidths=.5
    )
    plt.title("Feature Correlation Heatmap")
    plt.show()
    print("✔ Heatmap Completed.\n")

    print("🎉 EDA Completed Successfully!\n")

    return df


# ============================================================
# MAIN EXECUTION PIPELINE
# ============================================================

def omega_statistical_analysis(df):
    import pandas as pd
    import numpy as np

    print("\n📊===================================================")
    print("       OMEGA: STATISTICAL ANALYSIS STARTED")
    print("===================================================📊\n")

    # --------------------------------------------------
    # 1️⃣ CLASS IMBALANCE RATIO
    # --------------------------------------------------
    print("🔍 Step 1: Calculating Class Imbalance Ratio...")

    if "class_type" not in df.columns:
        print(" ERROR: 'class_type' column not found.")
    else:
        class_counts = df["class_type"].value_counts()

        print("\n Class Counts:")
        print(class_counts)

        largest = class_counts.max()
        smallest = class_counts.min()

        imbalance_ratio = largest / smallest

        print(f"\n📊 Class Imbalance Ratio = Largest / Smallest")
        print(f"➡ {largest} / {smallest} = {imbalance_ratio:.2f}\n")

    # --------------------------------------------------
    # 2️⃣ LOW VARIANCE FEATURES (variance < 0.01)
    # --------------------------------------------------
    print("🔍 Step 2: Detecting Low-Variance Features (< 0.01)...")

    numeric_df = df.select_dtypes(include=["number"])

    variance = numeric_df.var()

    low_var_features = variance[variance < 0.01].index.tolist()

    print("\n📉 Variances of numeric features:")
    print(variance)

    print("\n⚠️ Low-variance features (<0.01):")
    print(low_var_features if low_var_features else "None")

    # --------------------------------------------------
    # 3️⃣ HIGH CORRELATION PAIRS (|corr| > 0.8)
    # --------------------------------------------------
    print("\n🔍 Step 3: Highly Correlated Feature Pairs (|corr| > 0.8)...")

    corr_matrix = numeric_df.corr().abs()

    high_corr_pairs = []

    for i in range(len(corr_matrix.columns)):
        for j in range(i + 1, len(corr_matrix.columns)):
            col1 = corr_matrix.columns[i]
            col2 = corr_matrix.columns[j]
            corr_value = corr_matrix.iloc[i, j]
            if corr_value > 0.8:
                high_corr_pairs.append((col1, col2, corr_value))

    print("\n🔗 Pairs with |corr| > 0.8:")
    if high_corr_pairs:
        for col1, col2, val in high_corr_pairs:
            print(f"➡ {col1}  <==>  {col2}   (corr = {val:.2f})")
    else:
        print("None")

    # --------------------------------------------------
    # FINAL SUMMARY
    # --------------------------------------------------
    print("\n🎉===================================================")
    print("   OMEGA: STATISTICAL ANALYSIS COMPLETED SUCCESSFULLY")
    print("===================================================🎉\n")

    return {
        "imbalance_ratio": imbalance_ratio if "class_type" in df.columns else None,
        "low_variance_features": low_var_features,
        "high_corr_pairs": high_corr_pairs,
    }


if __name__ == "__main__":

    df, metadata = omega_load_and_integration()
    df = omega_normalization(df)
    df = omega_handle_missing_values(df)
    df = omega_feature_engineering(df)
    df = eda_53_and_cleaning(df)
    results = omega_statistical_analysis(df)

    print("\n🎉 OMEGA SYSTEM — ALL TASKS COMPLETED SUCCESSFULLY!")


